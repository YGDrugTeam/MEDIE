{
  "expo": {
    "name": "MedicHubs",
    "slug": "medichubs",
    "scheme": "medichubs",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "MedicHubs에서 촬영을 위해 카메라 접근이 필요합니다.",
          "microphonePermission": "영상 녹화를 위해 마이크 접근이 필요합니다.",
          "recordAudioAndroid": true
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "a0009540a1ff9149700c5d29557791d8"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "메디가 당신의 목소리를 듣고 대답하기 위해 마이크 권한이 필요합니다.",
          "speechRecognitionPermission": "메디가 당신의 음성을 텍스트로 변환하기 위해 음성 인식 권한이 필요합니다."
        }
      ],
      "expo-audio"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medichubs.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "a0009540a1ff9149700c5d29557791d8"
            ]
          }
        ],
        "NSLocationWhenInUseUsageDescription": "내 주변 당번약국을 찾기 위해 위치를 사용합니다.",
        "NSSpeechRecognitionUsageDescription": "메디가 당신의 음성을 텍스트로 변환하기 위해 음성 인식 권한이 필요합니다.",
        "NSMicrophoneUsageDescription": "메디가 당신의 목소리를 듣고 대답하기 위해 마이크 권한이 필요합니다.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.medichubs.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "08f29fdf-dd9f-49f9-ae32-fd713de175ff"
      }
    }
  }
}
